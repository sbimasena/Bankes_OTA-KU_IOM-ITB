// [OTA → SHARED] Kode fakultas ITB (14 fakultas).
// @map untuk mempertahankan format dengan tanda hubung di DB.
enum Fakultas {
  FMIPA
  SITH_S @map("SITH-S")
  SF
  FITB
  FTTM
  STEI_R @map("STEI-R")
  FTSL
  FTI
  FSRD
  FTMD
  STEI_K @map("STEI-K")
  SBM
  SITH_R @map("SITH-R")
  SAPPK
}

// [SHARED] Tipe dokumen mahasiswa.
// Gabungan dari Bankes FileType (KTP, CV, Transkrip_Nilai, Essay, STNK, SIM)
// + 9 kolom inline file OTA (kk, ktm, waliRecommendationLetter, dst.)
enum StudentFileType {
  // Bankes originals
  KTP
  CV
  Transkrip_Nilai
  Essay
  STNK
  SIM
  // OTA originals (sebelumnya kolom text di account_mahasiswa_detail)
  KK
  KTM
  Wali_Recommendation_Letter
  Transcript
  Salary_Report
  PBB
  Electricity_Bill
  Ditmawa_Recommendation_Letter
  Profile_Photo
}

// [OTA] Hubungan OTA donor dengan ITB.
enum Linkage {
  otm
  dosen
  alumni
  lainnya
  none
}

// [OTA] Status aktif mahasiswa dalam program OTA.
enum MahasiswaStatus {
  active
  inactive
}

// [OTA] Status koneksi antara mahasiswa dan OTA donor.
enum ConnectionStatus {
  accepted
  rejected
  pending
}

// [OTA] Status pembayaran transaksi.
enum TransactionStatus {
  pending
  paid
  unpaid
}

// [OTA] Status transfer dana dari IOM ke OTA.
enum TransferStatus {
  paid
  unpaid
}

// [OTA] Status moderasi testimoni mahasiswa.
enum TestimonialStatus {
  shown
  not_shown
}

// [BANKES] Kategori nilai wawancara.
enum ScoreCategory {
  KURANG
  CUKUP
  BAIK
}

// =============================================================================
// SHARED MODELS
// =============================================================================

// [SHARED] Akun pengguna terpusat.
// Menggabungkan: Bankes `User` (Int PK) + OTA `account` (UUID PK).
// PK sekarang UUID — Bankes code yang menggunakan Number(session.user.id) perlu diupdate.
// `name` disimpan di sini sebagai denormalized field untuk JWT (tanpa join ke profile).
model User {
  id                 String             @id @default(uuid()) @db.Uuid
  email              String             @unique @db.VarChar(255)
  phoneNumber        String?            @unique @db.VarChar(32) // OTA feature; null untuk user Bankes lama
  password           String?            @db.VarChar(255) // nullable untuk Azure-only users
  name               String?            // denormalized untuk JWT; sumber kebenaran di MahasiswaProfile.name
  role               Role
  provider           Provider           @default(credentials)
  verificationStatus VerificationStatus @default(unverified)
  applicationStatus  ApplicationStatus  @default(unregistered) // OTA lifecycle; Bankes ignore untuk non-Mahasiswa
  oid                String?            @db.VarChar(255) // Azure Object ID (untuk SSO)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Profile relations (1:1, optional berdasarkan role)
  MahasiswaProfile MahasiswaProfile?
  OtaProfile       OtaProfile?
  AdminProfile     AdminProfile?

  // Bankes relations
  Notifications          Notification[]
  PushSubscriptions      PushSubscription[]
  ParticipatedInterviews InterviewParticipant[]
  InterviewSlots         InterviewSlot[]

  // OTA auth extras (OTP & forgot password — fitur baru untuk Bankes)
  OTPs               OTP[]
  TemporaryPasswords TemporaryPassword[]

  ApprovedTestimonials Testimonial[] @relation("TestimonialApprover")

  @@map("users")
}

// [SHARED] Profil lengkap mahasiswa.
// Menggabungkan: Bankes `Student` (nim, faculty, major) + OTA `account_mahasiswa_detail` (semua field).
// userId = UUID FK ke User (1:1).
model MahasiswaProfile {
  userId  String    @id @db.Uuid
  nim     String    @unique @db.VarChar(8)
  name    String?   @db.VarChar(255)
  faculty Fakultas?
  major   Jurusan?

  // Extended profile — field dari OTA, baru untuk Bankes
  cityOfOrigin     String?  @db.VarChar(255)
  highschoolAlumni String?  @db.VarChar(255)
  religion         String?  @db.VarChar(50) // tidak pakai enum agar fleksibel
  gender           String?  @db.VarChar(1)  // "M" atau "F"
  gpa              Decimal? @db.Decimal(3, 2)
  description      String?

  // OTA program fields
  bill            Int             @default(0) // tagihan bulanan dalam IDR
  notes           String?         // catatan admin yang terlihat mahasiswa
  adminOnlyNotes  String?         // catatan internal admin saja
  mahasiswaStatus MahasiswaStatus @default(inactive)
  dueNextUpdateAt DateTime        @default(now()) // deadline update profil (untuk cron OTA)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // File storage — menggantikan Bankes File[] + 9 kolom inline OTA
  StudentFiles StudentFile[]

  // Bankes relations
  BankesStatuses BankesStatus[]
  InterviewSlots InterviewSlot[]
  InterviewNotes InterviewNote[]
  ScoreMatrices  ScoreMatrix[]

  // OTA relations
  Connections  Connection[]  @relation("MahasiswaConnections")
  Transactions Transaction[] @relation("MahasiswaTransactions")
  Testimonials Testimonial[]

  @@map("mahasiswa_profile")
}

// [SHARED] Dokumen/file mahasiswa yang tersimpan di MinIO.
// Menggantikan: Bankes `File` table + 9 kolom text inline di OTA.
// OTA sebelumnya pakai Cloudinary; setelah migrasi semua ke MinIO.
model StudentFile {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String          @db.Uuid
  fileUrl    String          // MinIO URL: http://{host}:{port}/{bucket}/{filename}
  fileName   String          // object name di MinIO bucket
  type       StudentFileType
  bucketName String          @default("documents-bucket")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  MahasiswaProfile MahasiswaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, type]) // satu file per tipe per mahasiswa (match logika upsert Bankes)
  @@map("student_file")
}

// [SHARED] Web Push notification subscription.
// Menggabungkan: Bankes `NotificationEndpoint` + OTA `push_subscription`.
// Struktur identik; OTA punya updatedAt yang sebelumnya tidak ada di Bankes.
model PushSubscription {
  userId    String   @db.Uuid
  endpoint  String
  keys      Json     // { p256dh: string, auth: string }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, endpoint])
  @@map("push_subscription")
}

// =============================================================================
// OTA-SPECIFIC MODELS
// =============================================================================

// [OTA] Profil OTA donor (Orang Tua Asuh).
// Dari: OTA `account_ota_detail`.
model OtaProfile {
  userId              String   @id @db.Uuid
  name                String   @db.VarChar(255)
  job                 String   @db.VarChar(255)
  address             String   @db.VarChar(255)
  linkage             Linkage
  funds               Int      // kontribusi bulanan dalam IDR
  maxCapacity         Int      // maksimum mahasiswa yang bisa disponsori
  startDate           DateTime
  maxSemester         Int
  transferDate        Int      // tanggal transfer per bulan (1-31)
  criteria            String   // kriteria mahasiswa yang dicari
  isDetailVisible     Boolean  @default(false)
  allowAdminSelection Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  User         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Connections  Connection[]  @relation("OtaConnections")
  Transactions Transaction[] @relation("OtaTransactions")

  @@map("ota_profile")
}

// [OTA + BANKES admin] Profil admin.
// Dari: OTA `account_admin_detail`. Bankes admin sebelumnya menyimpan name di User.
model AdminProfile {
  userId String @id @db.Uuid
  name   String @db.VarChar(255)

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profile")
}

// [OTA] Koneksi (matching) antara mahasiswa dan OTA donor.
// Composite PK: mahasiswaId + otaId.
model Connection {
  mahasiswaId               String           @db.Uuid
  otaId                     String           @db.Uuid
  connectionStatus          ConnectionStatus @default(pending)
  requestTerminateOta       Boolean          @default(false)
  requestTerminateMahasiswa Boolean          @default(false)
  requestTerminationNoteOta String?
  requestTerminationNoteMa  String?
  paidFor                   Int              // jumlah bulan yang sudah dibayarkan
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  MahasiswaProfile MahasiswaProfile @relation("MahasiswaConnections", fields: [mahasiswaId], references: [userId], onDelete: Cascade)
  OtaProfile       OtaProfile       @relation("OtaConnections", fields: [otaId], references: [userId], onDelete: Cascade)
  Transactions     Transaction[]

  @@id([mahasiswaId, otaId])
  @@map("connection")
}

// [OTA] Transaksi pembayaran bulanan OTA → mahasiswa.
model Transaction {
  id                 String            @id @default(uuid()) @db.Uuid
  mahasiswaId        String            @db.Uuid
  otaId              String            @db.Uuid
  bill               Int               // jumlah tagihan bulan ini
  amountPaid         Int               @default(0)
  paidAt             DateTime?
  dueDate            DateTime
  transactionStatus  TransactionStatus @default(unpaid)
  transferStatus     TransferStatus    @default(unpaid)
  transactionReceipt String?           // URL bukti transfer (Cloudinary atau MinIO)
  paidFor            Int               @default(0) // bulan ke berapa pembayaran ini
  rejectionNote      String?           // catatan penolakan verifikasi
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  MahasiswaProfile MahasiswaProfile @relation("MahasiswaTransactions", fields: [mahasiswaId], references: [userId], onDelete: Cascade)
  OtaProfile       OtaProfile       @relation("OtaTransactions", fields: [otaId], references: [userId], onDelete: Cascade)
  Connection       Connection       @relation(fields: [mahasiswaId, otaId], references: [mahasiswaId, otaId])

  @@map("transaction")
}

// [OTA] Testimoni mahasiswa untuk ditampilkan di landing page.
// Satu mahasiswa maksimal satu testimoni (bisa diupdate).
model Testimonial {
  id              String            @id @default(uuid()) @db.Uuid
  mahasiswaId     String            @db.Uuid
  periodId        Int
  content         String
  imageUrls       String[]
  status          TestimonialStatus @default(not_shown)
  isActive        Boolean           @default(false)
  approvedById    String?           @db.Uuid
  approvedAt      DateTime?
  rejectedReason  String?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  MahasiswaProfile MahasiswaProfile @relation(fields: [mahasiswaId], references: [userId], onDelete: Cascade)
  Period           Period           @relation(fields: [periodId], references: [id], onDelete: Cascade)
  Approver         User?            @relation("TestimonialApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([mahasiswaId, periodId])
  @@index([status, isActive, updatedAt])
  @@map("testimonial")
}

// [OTA] One-time password untuk verifikasi email saat registrasi.
model OTP {
  userId    String   @db.Uuid
  code      String   @db.VarChar(6)
  expiredAt DateTime

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, code])
  @@map("otp")
}

// [OTA] Temporary password untuk alur forgot-password.
model TemporaryPassword {
  userId    String   @db.Uuid
  password  String   @db.VarChar(255)
  expiredAt DateTime
  used      Boolean  @default(false)

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, password])
  @@map("temporary_password")
}

// =============================================================================
// BANKES-SPECIFIC MODELS
// =============================================================================

// [BANKES] Periode seleksi IOM (siklus penerimaan anggota).
// Int PK dipertahankan karena tidak ada kebutuhan UUID di sini.
model Period {
  id        Int      @id @default(autoincrement())
  period    String   // nama periode, misal "Periode 2025/1"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean
  isOpen    Boolean  // apakah pendaftaran sedang dibuka

  BankesStatuses BankesStatus[]
  InterviewSlots InterviewSlot[]
  ScoreMatrices  ScoreMatrix[]
  Testimonials   Testimonial[]

  @@map("period")
}

// [BANKES] Status seleksi mahasiswa per periode IOM.
// Renamed dari `Status` → `BankesStatus` untuk kejelasan.
// Track tiga tahap: Ditmawa → IOM → Wawancara.
model BankesStatus {
  userId        String  @db.Uuid
  periodId      Int
  passDitmawa   Boolean
  passIOM       Boolean
  passInterview Boolean
  amount        Int?    // nominal beasiswa (jika lolos)

  MahasiswaProfile MahasiswaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  Period           Period           @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@id([userId, periodId])
  @@map("bankes_status")
}

// [BANKES] Bank soal wawancara.
// Renamed dari `Questions` → `Question`.
model Question {
  id       Int    @id @default(autoincrement())
  question String

  ScoreMatrices ScoreMatrix[]

  @@map("question")
}

// [BANKES] Matriks penilaian wawancara per mahasiswa per periode per soal.
model ScoreMatrix {
  userId        String        @db.Uuid
  periodId      Int
  questionId    Int
  scoreCategory ScoreCategory
  comment       String

  MahasiswaProfile MahasiswaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  Period           Period           @relation(fields: [periodId], references: [id], onDelete: Cascade)
  Question         Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([userId, periodId, questionId])
  @@map("score_matrix")
}

// [BANKES] Slot waktu wawancara yang dibuat oleh pewawancara.
model InterviewSlot {
  id          Int       @id @default(autoincrement())
  title       String?
  description String?
  createdById String    @db.Uuid    // FK ke User (role: Pewawancara)
  periodId    Int
  startTime   DateTime
  endTime     DateTime
  studentId   String?   @db.Uuid    // FK ke MahasiswaProfile; null jika belum ada booking
  bookedAt    DateTime?

  CreatedBy    User                   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  Period       Period                 @relation(fields: [periodId], references: [id], onDelete: Cascade)
  Student      MahasiswaProfile?      @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  Participants InterviewParticipant[]
  Notes        InterviewNote[]

  @@map("interview_slot")
}

// [BANKES] Pewawancara yang ikut dalam satu slot wawancara (bisa lebih dari satu).
model InterviewParticipant {
  id       Int      @id @default(autoincrement())
  slotId   Int
  userId   String   @db.Uuid
  joinedAt DateTime @default(now())

  Slot InterviewSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  User User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([slotId, userId])
  @@map("interview_participant")
}

// [BANKES] Catatan pewawancara untuk mahasiswa pada slot wawancara tertentu.
// Renamed dari `Notes` → `InterviewNote`.
model InterviewNote {
  slotId Int
  userId String @db.Uuid // mahasiswa yang diwawancara

  text String

  Slot    InterviewSlot    @relation(fields: [slotId], references: [id], onDelete: Cascade)
  Student MahasiswaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([slotId, userId])
  @@map("interview_note")
}

// [BANKES] Inbox notifikasi in-app untuk user Bankes.
model Notification {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  header    String
  body      String
  url       String?
  hasRead   Boolean  @default(false)
  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification")
}
