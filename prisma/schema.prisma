// =============================================================================
// Unified Prisma Schema — Bankes IOM-ITB + OTA-KU
// =============================================================================
// Satu PostgreSQL database yang dipakai bersama kedua aplikasi.
//
// Legend:
//   [SHARED]  — dibaca/ditulis oleh kedua aplikasi
//   [BANKES]  — hanya dipakai Bankes (IOM-ITB)
//   [OTA]     — hanya dipakai OTA-KU
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

// [SHARED] Unified role — merge dari Bankes `Role` enum + OTA `account_type` enum.
// @map mempertahankan nilai string di DB agar tidak perlu ALTER DATA pada data OTA existing.
enum Role {
  Admin        @map("admin")
  Mahasiswa    @map("mahasiswa")
  Guest        @map("guest")
  Pengurus_IOM @map("pengurus")  // OTA: "pengurus"
  Pewawancara  @map("pewawancara") // Bankes only
  OrangTuaAsuh @map("ota")        // OTA: "ota"
  Bankes       @map("bankes")      // OTA: "bankes" (koordinator Bankes di sistem OTA)
}

// [OTA → SHARED] Status verifikasi email akun.
enum VerificationStatus {
  verified
  unverified
}

// [OTA → SHARED] Status aplikasi mahasiswa dalam proses OTA matching.
// Berbeda dari BankesStatus (per-periode seleksi IOM).
enum ApplicationStatus {
  accepted
  rejected
  pending
  unregistered
  reapply
  outdated
}

// [SHARED] Auth provider — credentials (email+password) atau Azure AD SSO.
enum Provider {
  credentials
  azure
}

