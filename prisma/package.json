{
  "name": "@iom-itb/db",
  "version": "1.0.0",
  "description": "Shared Prisma database package for Bankes IOM-ITB and OTA-KU",
  "main": "../generated/prisma/index.js",
  "types": "../generated/prisma/index.d.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:reset": "prisma migrate reset",
    "seed": "ts-node --esm seed/index.ts",
    "studio": "prisma studio",
    "validate": "prisma validate"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json seed/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "prisma": "^6.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "@types/node": "^22.0.0",
    "@types/bcryptjs": "^2.4.6"
  }
}
