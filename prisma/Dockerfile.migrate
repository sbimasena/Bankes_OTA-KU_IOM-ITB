FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
COPY schema.prisma ./
COPY scripts ./scripts/

RUN npm ci --quiet

CMD ["sh", "-c", "npx prisma db execute --url \"$DATABASE_URL\" --file ./scripts/prepush-testimonial-backfill.sql && npx prisma db push --skip-generate && echo 'Schema ready'"]
