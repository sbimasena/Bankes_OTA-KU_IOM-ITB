# =============================================================================
# PRODUCTION ENVIRONMENT TEMPLATE
# 1. Copy this file:  cp .env.production.example .env.production
# 2. Replace every CHANGE_ME value
# 3. Keep .env.production out of git (it's in .gitignore)
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_IP=195.110.58.17

# ── Ports (confirm with PO which ports are assigned to your team) ─────────────
BANKES_PORT=13031
OTA_BACKEND_PORT=13000
OTA_FRONTEND_PORT=15173
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=iomota
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=iom_ota_db
DATABASE_URL=postgresql://iomota:CHANGE_ME_strong_db_password@postgres:5432/iom_ota_db

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_BUCKET_NAME=documents-bucket
# File URLs served to browsers — must be HTTPS to avoid mixed content errors.
# Nginx proxies /minio-static/ → http://minio:9000/ so files load over HTTPS.
MINIO_PUBLIC_URL=https://bankes.iom-itb.id/minio-static

# ── Bankes IOM-ITB (NextAuth) ─────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
# Gunakan URL domain (bukan IP:port) jika nginx reverse proxy sudah aktif
NEXTAUTH_URL=https://bankes.iom-itb.id

# ── Admin User (created automatically on first start) ────────────────────────
ADMIN_EMAIL=admin@itb.ac.id
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
ADMIN_NAME=Administrator
ADMIN_ROLE=Admin

# ── OTA-KU URLs ───────────────────────────────────────────────────────────────
# OTA frontend diakses lewat subdirectory /ota (nginx strips prefix saat proxy)
OTA_FRONTEND_URL=https://bankes.iom-itb.id/ota
# Backend API diakses lewat /ota-api/ (nginx strips prefix saat proxy ke backend:3000)
OTA_FRONTEND_API_URL=https://bankes.iom-itb.id/ota-api
# JSON array — origin harus match domain (tanpa path)
OTA_ALLOWED_ORIGINS=["https://bankes.iom-itb.id"]

# ── Shared Secrets ────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Azure AD (leave empty if SSO is not used) ─────────────────────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Email (use Gmail App Password, not your real password) ───────────────────
EMAIL=your-email@gmail.com
EMAIL_FROM=OTA-KU <your-email@gmail.com>
EMAIL_PASSWORD=CHANGE_ME_app_password
VAPID_MAILTO=admin@itb.ac.id
TEST_EMAIL=test@itb.ac.id

# ── VAPID Keys (Web Push Notifications) ──────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME

# ── Cloudinary (set placeholder if not actively used — MinIO handles files) ──
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# ── Payment ───────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=none
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_IS_PRODUCTION=false

# ── WhatsApp (optional) ───────────────────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# ── Keycloak SSO (shared) ─────────────────────────────────────────────────────
KEYCLOAK_ISSUER_URL=https://iom-sso.kirisame.jp.net/realms/iom-itb-sso
SSO_API_URL=https://iom-api.kirisame.jp.net
REGISTER_API_KEY=CHANGE_ME

# Bankes IOM-ITB Keycloak client (client id = bankes-app)
BANKES_KEYCLOAK_CLIENT_ID=bankes-app
BANKES_KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# OTA-KU Keycloak client (client id = ota-ku-app)
KEYCLOAK_CLIENT_ID=ota-ku-app
KEYCLOAK_CLIENT_SECRET=CHANGE_ME
KEYCLOAK_JWKS_URI=https://iom-sso.kirisame.jp.net/realms/iom-itb-sso/protocol/openid-connect/certs
KEYCLOAK_REDIRECT_URI=https://bankes.iom-itb.id/ota/integrations/keycloak/callback
COOKIE_SECURE=true
# Frontend build args
VITE_KEYCLOAK_CLIENT_ID=ota-ku-app
VITE_KEYCLOAK_REDIRECT_URI=https://bankes.iom-itb.id/ota/integrations/keycloak/callback
# Cross-app navigation (compose derives these from NEXTAUTH_URL and OTA_FRONTEND_URL automatically)
NEXT_PUBLIC_OTA_URL=https://bankes.iom-itb.id/ota
VITE_BANKES_URL=https://bankes.iom-itb.id
