# Root .env for Docker Compose variable substitution
# ─────────────────────────────────────────────────────────────────────────────
# This file controls shared infrastructure (Bankes, email, VAPID, Midtrans).
# OTA-KU Backend secrets (Keycloak, JWT, DB) live in OTA-KU/backend/.env
# and are loaded directly into the container via env_file in docker-compose.yml.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=iom_ota_db

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Bankes IOM-ITB ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3031

# Azure AD (Bankes only — OTA-KU has migrated to Keycloak SSO)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ── OTA-KU Frontend (baked into Vite build) ───────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_APP_URL=http://localhost:5173
VITE_KEYCLOAK_CLIENT_ID=ota-ku-app
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173/integrations/keycloak/callback
VITE_VAPID_PUBLIC_KEY=

# ── VAPID (Web Push Notifications) ───────────────────────────────────────────
VAPID_MAILTO=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL=
EMAIL_FROM=
EMAIL_PASSWORD=
TEST_EMAIL=

# Midtrans Payment Gateway
PAYMENT_PROVIDER=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_IS_PRODUCTION=false
