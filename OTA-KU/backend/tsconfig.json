{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist"
  },
  "exclude": [
    "node_modules",
    "src/db/drizzle.ts",
    "src/db/schema.ts",
    "src/db/scripts",
    "src/db/seed.ts",
    "src/db/reset.ts",
    "src/lib/cloudinary.ts",
    "src/lib/file-upload.ts"
  ]
}