// =============================================================================
// Unified Prisma Schema — OTA-KU copy (generates to local node_modules)
// Copied from root /prisma/schema.prisma — do NOT edit here, sync from root.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  Admin        @map("admin")
  Mahasiswa    @map("mahasiswa")
  Guest        @map("guest")
  Pengurus_IOM @map("pengurus")
  Pewawancara  @map("pewawancara")
  OrangTuaAsuh @map("ota")
  Bankes       @map("bankes")
}

enum VerificationStatus {
  verified
  unverified
}

enum ApplicationStatus {
  accepted
  rejected
  pending
  unregistered
  reapply
  outdated
}

enum Provider {
  credentials
  azure
}

enum Jurusan {
  Matematika
  Fisika
  Astronomi
  Mikrobiologi
  Kimia
  Biologi
  Sains_dan_Teknologi_Farmasi
  Aktuaria
  Rekayasa_Hayati
  Rekayasa_Pertanian
  Rekayasa_Kehutanan
  Farmasi_Klinik_dan_Komunitas
  Teknologi_Pasca_Panen
  Teknik_Geologi
  Teknik_Pertambangan
  Teknik_Perminyakan
  Teknik_Geofisika
  Teknik_Metalurgi
  Meteorologi
  Oseanografi
  Teknik_Kimia
  Teknik_Mesin
  Teknik_Elektro
  Teknik_Fisika
  Teknik_Industri
  Teknik_Informatika
  Aeronotika_dan_Astronotika
  Teknik_Material
  Teknik_Pangan
  Manajemen_Rekayasa_Industri
  Teknik_Bioenergi_dan_Kemurgi
  Teknik_Sipil
  Teknik_Geodesi_dan_Geomatika
  Arsitektur
  Teknik_Lingkungan
  Perencanaan_Wilayah_dan_Kota
  Teknik_Kelautan
  Rekayasa_Infrastruktur_Lingkungan
  Teknik_dan_Pengelolaan_Sumber_Daya_Air
  Seni_Rupa
  Desain
  Kriya
  Desain_Interior
  Desain_Komunikasi_Visual
  Desain_Produk
  Teknik_Tenaga_Listrik
  Teknik_Telekomunikasi
  Sistem_Teknologi_dan_Informasi
  Teknik_Biomedis
  Manajemen
  Kewirausahaan
  TPB
}

enum Fakultas {
  FMIPA
  SITH_S @map("SITH-S")
  SF
  FITB
  FTTM
  STEI_R @map("STEI-R")
  FTSL
  FTI
  FSRD
  FTMD
  STEI_K @map("STEI-K")
  SBM
  SITH_R @map("SITH-R")
  SAPPK
}

enum StudentFileType {
  KTP
  CV
  Transkrip_Nilai
  Essay
  STNK
  SIM
  KK
  KTM
  Wali_Recommendation_Letter
  Transcript
  Salary_Report
  PBB
  Electricity_Bill
  Ditmawa_Recommendation_Letter
  Profile_Photo
}

enum Linkage {
  otm
  dosen
  alumni
  lainnya
  none
}

enum MahasiswaStatus {
  active
  inactive
}

enum ConnectionStatus {
  accepted
  rejected
  pending
}

enum TransactionStatus {
  pending
  paid
  unpaid
}

enum TransferStatus {
  paid
  unpaid
}

enum OtaGroupStatus {
  forming
  active
}

enum GroupInvitationStatus {
  pending
  accepted
  rejected
  cancelled
}

enum ProposalStatus {
  open
  failed
  passed
  approved
  rejected
}

enum ScoreCategory {
  KURANG
  CUKUP
  BAIK
}

// =============================================================================
// SHARED MODELS
// =============================================================================

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  email              String             @unique @db.VarChar(255)
  phoneNumber        String?            @unique @db.VarChar(32)
  password           String?            @db.VarChar(255)
  name               String?
  role               Role
  provider           Provider           @default(credentials)
  verificationStatus VerificationStatus @default(unverified)
  applicationStatus  ApplicationStatus  @default(unregistered)
  oid                String?            @db.VarChar(255)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  MahasiswaProfile MahasiswaProfile?
  OtaProfile       OtaProfile?
  AdminProfile     AdminProfile?

  Notifications          Notification[]
  PushSubscriptions      PushSubscription[]
  ParticipatedInterviews InterviewParticipant[]
  InterviewSlots         InterviewSlot[]

  OTPs               OTP[]
  TemporaryPasswords TemporaryPassword[]

  CreatedGroups OtaGroup[]

  @@map("users")
}

model MahasiswaProfile {
  userId  String    @id @db.Uuid
  nim     String    @unique @db.VarChar(8)
  name    String?   @db.VarChar(255)
  faculty Fakultas?
  major   Jurusan?

  cityOfOrigin     String?  @db.VarChar(255)
  highschoolAlumni String?  @db.VarChar(255)
  religion         String?  @db.VarChar(50)
  gender           String?  @db.VarChar(1)
  gpa              Decimal? @db.Decimal(3, 2)
  description      String?

  bill            Int             @default(0)
  notes           String?
  adminOnlyNotes  String?
  mahasiswaStatus MahasiswaStatus @default(inactive)
  dueNextUpdateAt DateTime        @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  StudentFiles StudentFile[]

  BankesStatuses BankesStatus[]
  InterviewSlots InterviewSlot[]
  InterviewNotes InterviewNote[]
  ScoreMatrices  ScoreMatrix[]

  Connections  Connection[]  @relation("MahasiswaConnections")
  Transactions Transaction[] @relation("MahasiswaTransactions")

  GroupConnections  GroupConnection[]
  GroupTransactions GroupTransaction[]
  GroupProposals    GroupStudentProposal[]

  @@map("mahasiswa_profile")
}

model StudentFile {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String          @db.Uuid
  fileUrl    String
  fileName   String
  type       StudentFileType
  bucketName String          @default("documents-bucket")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  MahasiswaProfile MahasiswaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, type])
  @@map("student_file")
}

model PushSubscription {
  userId    String   @db.Uuid
  endpoint  String
  keys      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, endpoint])
  @@map("push_subscription")
}

// =============================================================================
// OTA-SPECIFIC MODELS
// =============================================================================

model OtaProfile {
  userId              String   @id @db.Uuid
  name                String   @db.VarChar(255)
  job                 String   @db.VarChar(255)
  address             String   @db.VarChar(255)
  linkage             Linkage
  funds               Int
  maxCapacity         Int
  startDate           DateTime
  maxSemester         Int
  transferDate        Int
  criteria            String
  isDetailVisible     Boolean  @default(false)
  allowAdminSelection Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  User         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Connections  Connection[]  @relation("OtaConnections")
  Transactions Transaction[] @relation("OtaTransactions")

  GroupMemberships         OtaGroupMember[]
  SentInvitations          GroupInvitation[]          @relation("SentInvitations")
  ReceivedInvitations      GroupInvitation[]          @relation("ReceivedInvitations")
  ProposalVotes            GroupStudentProposalVote[]
  ProposedStudents         GroupStudentProposal[]     @relation("ProposedByOta")
  GroupMemberContributions GroupMemberContribution[]
  GroupMemberTransactions  GroupMemberTransaction[]

  @@map("ota_profile")
}

model AdminProfile {
  userId String @id @db.Uuid
  name   String @db.VarChar(255)

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profile")
}

model Connection {
  mahasiswaId               String           @db.Uuid
  otaId                     String           @db.Uuid
  connectionStatus          ConnectionStatus @default(pending)
  requestTerminateOta       Boolean          @default(false)
  requestTerminateMahasiswa Boolean          @default(false)
  requestTerminationNoteOta String?
  requestTerminationNoteMa  String?
  paidFor                   Int
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  MahasiswaProfile MahasiswaProfile @relation("MahasiswaConnections", fields: [mahasiswaId], references: [userId], onDelete: Cascade)
  OtaProfile       OtaProfile       @relation("OtaConnections", fields: [otaId], references: [userId], onDelete: Cascade)
  Transactions     Transaction[]

  @@id([mahasiswaId, otaId])
  @@map("connection")
}

model Transaction {
  id                 String            @id @default(uuid()) @db.Uuid
  mahasiswaId        String            @db.Uuid
  otaId              String            @db.Uuid
  bill               Int
  amountPaid         Int               @default(0)
  paidAt             DateTime?
  dueDate            DateTime
  transactionStatus  TransactionStatus @default(unpaid)
  transferStatus     TransferStatus    @default(unpaid)
  transactionReceipt String?
  paidFor            Int               @default(0)
  rejectionNote      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  MahasiswaProfile MahasiswaProfile @relation("MahasiswaTransactions", fields: [mahasiswaId], references: [userId], onDelete: Cascade)
  OtaProfile       OtaProfile       @relation("OtaTransactions", fields: [otaId], references: [userId], onDelete: Cascade)
  Connection       Connection       @relation(fields: [mahasiswaId, otaId], references: [mahasiswaId, otaId])

  @@map("transaction")
}

model OTP {
  userId    String   @db.Uuid
  code      String   @db.VarChar(6)
  expiredAt DateTime

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, code])
  @@map("otp")
}

model TemporaryPassword {
  userId    String   @db.Uuid
  password  String   @db.VarChar(255)
  expiredAt DateTime
  used      Boolean  @default(false)

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, password])
  @@map("temporary_password")
}

// =============================================================================
// OTA GROUP MODELS
// =============================================================================

model OtaGroup {
  id           String         @id @default(uuid()) @db.Uuid
  name         String         @db.VarChar(255)
  description  String?
  status       OtaGroupStatus @default(forming)
  criteria     String?
  transferDate Int?
  createdById  String         @db.Uuid
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  CreatedBy    User                   @relation(fields: [createdById], references: [id])
  Members      OtaGroupMember[]
  Invitations  GroupInvitation[]
  Proposals    GroupStudentProposal[]
  Connections  GroupConnection[]
  Transactions GroupTransaction[]

  @@map("ota_group")
}

model OtaGroupMember {
  groupId      String   @db.Uuid
  otaId        String   @db.Uuid
  pledgeAmount Int      @default(0)
  joinedAt     DateTime @default(now())

  Group OtaGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Ota   OtaProfile @relation(fields: [otaId], references: [userId], onDelete: Cascade)

  @@id([groupId, otaId])
  @@map("ota_group_member")
}

model GroupInvitation {
  id             String                @id @default(uuid()) @db.Uuid
  groupId        String                @db.Uuid
  invitedOtaId   String                @db.Uuid
  invitedByOtaId String?               @db.Uuid
  status         GroupInvitationStatus @default(pending)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  Group      OtaGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  InvitedOta OtaProfile  @relation("ReceivedInvitations", fields: [invitedOtaId], references: [userId], onDelete: Cascade)
  InvitedBy  OtaProfile? @relation("SentInvitations", fields: [invitedByOtaId], references: [userId], onDelete: SetNull)

  @@map("group_invitation")
}

model GroupStudentProposal {
  id           String         @id @default(uuid()) @db.Uuid
  groupId      String         @db.Uuid
  mahasiswaId  String         @db.Uuid
  proposedById String?        @db.Uuid
  status       ProposalStatus @default(open)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  Group      OtaGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Mahasiswa  MahasiswaProfile @relation(fields: [mahasiswaId], references: [userId], onDelete: Cascade)
  ProposedBy OtaProfile?      @relation("ProposedByOta", fields: [proposedById], references: [userId], onDelete: SetNull)
  Votes      GroupStudentProposalVote[]
  Connection GroupConnection?

  @@map("group_student_proposal")
}

model GroupStudentProposalVote {
  proposalId   String   @db.Uuid
  otaId        String   @db.Uuid
  approve      Boolean
  pledgeAmount Int
  votedAt      DateTime @default(now())

  Proposal GroupStudentProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  Ota      OtaProfile           @relation(fields: [otaId], references: [userId], onDelete: Cascade)

  @@id([proposalId, otaId])
  @@map("group_student_proposal_vote")
}

model GroupConnection {
  id                          String           @id @default(uuid()) @db.Uuid
  mahasiswaId                 String           @db.Uuid
  groupId                     String           @db.Uuid
  proposalId                  String?          @unique @db.Uuid
  connectionStatus            ConnectionStatus @default(pending)
  requestTerminateGroup       Boolean          @default(false)
  requestTerminateMahasiswa   Boolean          @default(false)
  requestTerminationNoteGroup String?
  requestTerminationNoteMa    String?
  paidFor                     Int              @default(0)
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt

  Mahasiswa           MahasiswaProfile          @relation(fields: [mahasiswaId], references: [userId], onDelete: Cascade)
  Group               OtaGroup                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Proposal            GroupStudentProposal?     @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  MemberContributions GroupMemberContribution[]
  Transactions        GroupTransaction[]

  @@unique([mahasiswaId, groupId])
  @@map("group_connection")
}

model GroupMemberContribution {
  groupConnectionId String @db.Uuid
  otaId             String @db.Uuid
  amount            Int

  GroupConnection GroupConnection @relation(fields: [groupConnectionId], references: [id], onDelete: Cascade)
  Ota             OtaProfile      @relation(fields: [otaId], references: [userId], onDelete: Cascade)

  @@id([groupConnectionId, otaId])
  @@map("group_member_contribution")
}

model GroupTransaction {
  id                String            @id @default(uuid()) @db.Uuid
  mahasiswaId       String            @db.Uuid
  groupId           String            @db.Uuid
  groupConnectionId String            @db.Uuid
  bill              Int
  paidFor           Int               @default(0)
  dueDate           DateTime
  transactionStatus TransactionStatus @default(unpaid)
  transferStatus    TransferStatus    @default(unpaid)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  Mahasiswa       MahasiswaProfile         @relation(fields: [mahasiswaId], references: [userId], onDelete: Cascade)
  Group           OtaGroup                 @relation(fields: [groupId], references: [id], onDelete: Cascade)
  GroupConnection GroupConnection          @relation(fields: [groupConnectionId], references: [id], onDelete: Cascade)
  MemberPayments  GroupMemberTransaction[]

  @@map("group_transaction")
}

model GroupMemberTransaction {
  id                 String            @id @default(uuid()) @db.Uuid
  groupTransactionId String            @db.Uuid
  otaId              String            @db.Uuid
  expectedAmount     Int
  amountPaid         Int               @default(0)
  transactionReceipt String?
  paymentStatus      TransactionStatus @default(unpaid)
  transferStatus     TransferStatus    @default(unpaid)
  rejectionNote      String?
  paidAt             DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  GroupTransaction GroupTransaction @relation(fields: [groupTransactionId], references: [id], onDelete: Cascade)
  Ota              OtaProfile       @relation(fields: [otaId], references: [userId], onDelete: Cascade)

  @@unique([groupTransactionId, otaId])
  @@map("group_member_transaction")
}

// =============================================================================
// BANKES-SPECIFIC MODELS
// =============================================================================

model Period {
  id        Int      @id @default(autoincrement())
  period    String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean
  isOpen    Boolean

  BankesStatuses BankesStatus[]
  InterviewSlots InterviewSlot[]
  ScoreMatrices  ScoreMatrix[]

  @@map("period")
}

model BankesStatus {
  userId        String  @db.Uuid
  periodId      Int
  passDitmawa   Boolean
  passIOM       Boolean
  passInterview Boolean
  amount        Int?

  MahasiswaProfile MahasiswaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  Period           Period           @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@id([userId, periodId])
  @@map("bankes_status")
}

model Question {
  id       Int    @id @default(autoincrement())
  question String

  ScoreMatrices ScoreMatrix[]

  @@map("question")
}

model ScoreMatrix {
  userId        String        @db.Uuid
  periodId      Int
  questionId    Int
  scoreCategory ScoreCategory
  comment       String

  MahasiswaProfile MahasiswaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  Period           Period           @relation(fields: [periodId], references: [id], onDelete: Cascade)
  Question         Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([userId, periodId, questionId])
  @@map("score_matrix")
}

model InterviewSlot {
  id          Int       @id @default(autoincrement())
  title       String?
  description String?
  createdById String    @db.Uuid
  periodId    Int
  startTime   DateTime
  endTime     DateTime
  studentId   String?   @db.Uuid
  bookedAt    DateTime?

  CreatedBy    User                   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  Period       Period                 @relation(fields: [periodId], references: [id], onDelete: Cascade)
  Student      MahasiswaProfile?      @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  Participants InterviewParticipant[]
  Notes        InterviewNote[]

  @@map("interview_slot")
}

model InterviewParticipant {
  id       Int      @id @default(autoincrement())
  slotId   Int
  userId   String   @db.Uuid
  joinedAt DateTime @default(now())

  Slot InterviewSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  User User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([slotId, userId])
  @@map("interview_participant")
}

model InterviewNote {
  slotId Int
  userId String @db.Uuid

  text String

  Slot    InterviewSlot    @relation(fields: [slotId], references: [id], onDelete: Cascade)
  Student MahasiswaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([slotId, userId])
  @@map("interview_note")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  header    String
  body      String
  url       String?
  hasRead   Boolean  @default(false)
  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification")
}
